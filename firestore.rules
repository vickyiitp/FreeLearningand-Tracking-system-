rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin Override: The Lead Architect can see everything
    match /{document=**} {
      allow read: if request.auth != null && request.auth.token.email == "vickyykumar14@gmail.com";
    }

    // User Data Rules
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /earnings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /challenges/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /planner/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
